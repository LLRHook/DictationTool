<Window x:Class="DictationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dictation Tool" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="PlayButton" Content="Play" Width="90" Height="32"
                    Click="PlayButton_Click" Margin="0,0,6,0" Focusable="False"/>
            <Button x:Name="PauseButton" Content="Pause" Width="90" Height="32"
                    Click="PauseButton_Click" Margin="0,0,6,0" IsEnabled="False" Focusable="False"/>
            <Button x:Name="StopButton" Content="Stop" Width="90" Height="32"
                    Click="StopButton_Click" Margin="0,0,6,0" IsEnabled="False" Focusable="False"/>

            <TextBlock Text="Voice:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <ComboBox x:Name="VoiceCombo" Width="220" Height="32"
                      SelectionChanged="VoiceCombo_SelectionChanged" Focusable="False"/>

            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <Slider x:Name="RateSlider" Width="100" Minimum="0.5" Maximum="2.0" Value="1.0"
                    VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.1"
                    ValueChanged="RateSlider_ValueChanged" Focusable="False"/>
            <TextBlock x:Name="RateLabel" Text="1.0x" VerticalAlignment="Center" Width="30" Margin="4,0,0,0"/>
        </StackPanel>

        <TextBox x:Name="InputBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="16"
                 FontFamily="Segoe UI"
                 Padding="8"
                 SelectionBrush="#FFEB3B"
                 SelectionOpacity="1.0">
        </TextBox>
    </DockPanel>
</Window>
